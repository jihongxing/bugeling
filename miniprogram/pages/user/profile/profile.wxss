/* pages/user/profile/profile.wxss */
.page {
  padding: 32rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.credit-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.score-section {
  text-align: center;
  margin-bottom: 32rpx;
}

.score-label {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.score-value {
  display: block;
  font-size: 80rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.2;
  margin-bottom: 16rpx;
}

.stats-section {
  display: flex;
  justify-content: center;
  gap: 80rpx;
  margin-bottom: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.level-section {
  text-align: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.level-text {
  font-size: 28rpx;
  color: #666;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.nav-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.nav-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #eee;
  font-size: 30rpx;
  color: #333;
}

.nav-item:last-child {
  border-bottom: none;
}

.nav-arrow {
  color: #ccc;
  font-size: 28rpx;
}
