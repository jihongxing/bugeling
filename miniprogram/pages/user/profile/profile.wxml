<!-- pages/user/profile/profile.wxml - 个人中心 -->
<view class="page">
  <view class="credit-card" wx:if="{{creditInfo}}">
    <view class="score-section">
      <text class="score-label">契约信用分</text>
      <text class="score-value">{{creditInfo.score}}</text>
      <credit-badge score="{{creditInfo.score}}" />
    </view>
    <view class="stats-section">
      <view class="stat-item">
        <text class="stat-value">{{creditInfo.totalVerified}}</text>
        <text class="stat-label">累计守约</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{creditInfo.totalBreached}}</text>
        <text class="stat-label">累计违约</text>
      </view>
    </view>
    <view class="level-section">
      <text class="level-text">{{creditInfo.level}}</text>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="nav-list">
    <view class="nav-item" bindtap="goToHistory" data-role="initiator">
      <text>我发起的活动</text>
      <text class="nav-arrow">></text>
    </view>
    <view class="nav-item" bindtap="goToHistory" data-role="participant">
      <text>我参与的活动</text>
      <text class="nav-arrow">></text>
    </view>
    <view class="nav-item" bindtap="goToCalendar">
      <text>我的契约日程</text>
      <text class="nav-arrow">></text>
    </view>
    <view class="nav-item" bindtap="goToPoster">
      <text>守约月报海报</text>
      <text class="nav-arrow">></text>
    </view>
    <view class="nav-item" bindtap="goToSettings">
      <text>设置</text>
      <text class="nav-arrow">></text>
    </view>
  </view>
</view>
