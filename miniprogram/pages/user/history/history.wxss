/* pages/user/history/history.wxss */
.page {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.activity-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx 24rpx;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.status-pending {
  color: #F59E0B;
  background: rgba(245, 158, 11, 0.1);
}

.status-active {
  color: #10B981;
  background: rgba(16, 185, 129, 0.1);
}

.status-completed {
  color: #6B7280;
  background: rgba(107, 114, 128, 0.1);
}

.status-cancelled {
  color: #EF4444;
  background: rgba(239, 68, 68, 0.1);
}

.activity-meta {
  margin-bottom: 8rpx;
}

.activity-time {
  font-size: 24rpx;
  color: #999;
}

.participation-status {
  font-size: 24rpx;
  color: #666;
  padding-top: 8rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 8rpx;
}

.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 32rpx;
  color: #999;
  font-size: 26rpx;
}

.load-more {
  text-align: center;
  padding: 24rpx;
}

.load-more-text {
  font-size: 24rpx;
  color: #ccc;
}
