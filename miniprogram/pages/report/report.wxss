/* pages/report/report.wxss */

.section-title {
  font-size: var(--font-size-md);
  font-weight: 500;
  color: var(--color-secondary);
  margin-bottom: 20rpx;
}

/* 单选按钮组 */
.radio-group {
  display: flex;
  flex-direction: column;
}

.radio-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  font-size: var(--font-size-md);
  color: var(--color-secondary);
}

.radio-item radio {
  margin-right: 16rpx;
}

/* 描述输入框 */
.desc-textarea {
  width: 100%;
  height: 200rpx;
  font-size: var(--font-size-md);
  color: var(--color-secondary);
  background-color: var(--color-bg);
  border-radius: var(--radius-input);
  padding: 20rpx;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

/* 图片上传区域 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-input);
}

.delete-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: var(--color-danger);
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--color-text-secondary);
  border-radius: var(--radius-input);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 56rpx;
  color: var(--color-text-secondary);
  line-height: 1;
}

.add-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

/* 提交按钮 */
.submit-btn {
  margin-top: 40rpx;
  width: 100%;
}

.submit-btn[disabled] {
  background-color: #ccc;
  color: #fff;
}
