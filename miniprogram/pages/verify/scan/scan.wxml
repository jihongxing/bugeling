<!-- pages/verify/scan/scan.wxml - 扫码核销 -->
<view class="page">
  <view class="success-overlay" wx:if="{{showSuccess}}">
    <view class="success-icon">✓</view>
    <text class="success-text">核销成功</text>
  </view>

  <view class="scan-section">
    <text class="scan-tip">请扫描参与者的核销码</text>
    <button class="scan-btn" bindtap="handleScan" disabled="{{scanning}}">
      {{scanning ? '扫码中...' : '扫码核销'}}
    </button>
  </view>

  <view class="participants-section">
    <text class="section-title">参与者核销状态</text>
    <view class="participant-list">
      <view class="participant-item" wx:for="{{participants}}" wx:key="_id">
        <text class="participant-status">{{item.displayStatus}}</text>
      </view>
      <view class="empty-tip" wx:if="{{participants.length === 0}}">
        <text>暂无参与者</text>
      </view>
    </view>
  </view>

  <view class="arrival-section">
    <button class="arrival-btn {{arrived ? 'arrived' : ''}}" bindtap="handleArrival" disabled="{{arrived}}">
      {{arrived ? '已报告到达 ✓' : '我已到达现场'}}
    </button>
  </view>
</view>
