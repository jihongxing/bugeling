<!-- pages/verify/qrcode/qrcode.wxml - 核销码展示 -->
<view class="page">
  <view class="header" wx:if="{{activityTitle}}">
    <text class="title">{{activityTitle}}</text>
  </view>

  <view class="qr-container">
    <view class="qr-wrapper" wx:if="{{!loading && !error}}">
      <canvas type="2d" id="qrCanvas" class="qr-canvas"></canvas>
    </view>
    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="error" wx:if="{{error}}">
      <text>{{error}}</text>
      <button class="retry-btn" bindtap="refreshQrCode">重试</button>
    </view>
  </view>

  <view class="countdown" wx:if="{{!loading && !error}}">
    <text class="countdown-text">{{countdown}}s 后自动刷新</text>
  </view>

  <view class="tips">
    <text class="tip-text">请向发起人出示此码</text>
    <text class="tip-text warning">截图无效，请使用实时码</text>
  </view>

  <view class="arrival-section">
    <button class="arrival-btn {{arrived ? 'arrived' : ''}}" bindtap="handleArrival" disabled="{{arrived}}">
      {{arrived ? '已报告到达 ✓' : '我已到达现场'}}
    </button>
    <button class="btn-secondary report-btn" bindtap="goReport">举报</button>
  </view>
</view>
