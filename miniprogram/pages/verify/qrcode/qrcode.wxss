/* pages/verify/qrcode/qrcode.wxss */
.page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx;
  min-height: 100vh;
  background: #F5F5F7;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.qr-container {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 480rpx;
  height: 480rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 32rpx;
}

.qr-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
}

.qr-canvas {
  width: 400rpx;
  height: 400rpx;
}

.loading,
.error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.error {
  color: #FF4D4F;
}

.retry-btn {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #FF6B35;
  background: transparent;
  border: 2rpx solid #FF6B35;
  border-radius: 8rpx;
  padding: 8rpx 32rpx;
}

.countdown {
  margin-bottom: 32rpx;
}

.countdown-text {
  font-size: 32rpx;
  color: #FF6B35;
  font-weight: 500;
}

.tips {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #6B7280;
  line-height: 1.8;
}

.tip-text.warning {
  color: #FF4D4F;
  font-size: 24rpx;
}

.arrival-section {
  width: 100%;
  padding: 0 32rpx;
}

.arrival-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  color: #FFFFFF;
  background: #FF6B35;
  border-radius: 16rpx;
  border: none;
}

.arrival-btn.arrived {
  background: #52C41A;
}

.arrival-btn[disabled] {
  opacity: 0.7;
}
