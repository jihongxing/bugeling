/* pages/index/index.wxss */
.location-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.location-name {
  font-size: var(--font-size-md);
  color: var(--color-secondary);
  font-weight: 500;
}

.refresh-btn {
  padding: 8rpx 16rpx;
}

.refresh-icon {
  font-size: var(--font-size-lg);
  color: var(--color-primary);
}

.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

.loading-tip,
.no-more-tip {
  text-align: center;
  padding: 24rpx 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
